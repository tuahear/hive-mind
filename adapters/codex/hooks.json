{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '\"$HOME/.hive-mind/bin/sync\" >/dev/null 2>>\"$HOME/.hive-mind/.sync-error.log\" || true; OUT=$(ADAPTER_DIR=\"$HOME/.codex\" ADAPTER_GLOBAL_MEMORY=\"$HOME/.codex/AGENTS.override.md\" \"$HOME/.hive-mind/hive-mind/core/check-dupes.sh\" 2>>\"$HOME/.codex/.sync-error.log\"); [ -n \"$OUT\" ] && printf \"%s\" \"$OUT\" || printf \"{}\"'",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '\"$HOME/.hive-mind/bin/sync\" >/dev/null 2>>\"$HOME/.hive-mind/.sync-error.log\" || true; printf \"{}\"'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
