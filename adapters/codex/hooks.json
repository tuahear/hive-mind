{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HIVE_MIND_ROOT/core/hub/codex-hook-session-start.sh $ADAPTER_DIR_ABS",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HIVE_MIND_ROOT/core/hub/codex-hook-stop.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
