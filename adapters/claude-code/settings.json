{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HIVE_MIND_HOOK claude-code session-start $ADAPTER_DIR_ARG",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HIVE_MIND_HOOK claude-code stop",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HIVE_MIND_HOOK claude-code post-tool-use $ADAPTER_DIR_ARG",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
