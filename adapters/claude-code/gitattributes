# Auto-merge append-style content on conflict. Git's built-in `union` driver
# concatenates both sides' conflicting hunks instead of leaving conflict
# markers. Fits how agents edit these files (adding bullets / memory entries) —
# duplicates are possible but a later agent turn can dedupe.
CLAUDE.md          merge=union
projects/**/*.md   merge=union

# Line-based config files that are ok to union on conflict. setup.sh always
# re-seeds them from the templates, so divergence windows are small anyway.
# Union beats default 3-way merge here because these are append-style files
# where duplicate lines are harmless.
.gitignore         merge=union
.gitattributes     merge=union
